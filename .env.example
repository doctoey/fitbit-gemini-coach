# ===================================================
# 🏃 AI Health Coach — Environment Variables
# ===================================================
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริงทั้งหมด
# ⚠️  ห้าม commit ไฟล์ .env เข้า Git โดยเด็ดขาด!
# ===================================================

# --------------------------------------------------
# Google OAuth 2.0 Credentials
# ดูได้จาก Google Cloud Console > APIs & Services > Credentials
# --------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# --------------------------------------------------
# Gemini AI
# สร้างได้จาก https://aistudio.google.com/app/apikey
# --------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key

# --------------------------------------------------
# Discord Webhook
# สร้างได้จาก Discord Server Settings > Integrations > Webhooks
# --------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# --------------------------------------------------
# ตั้งค่าอื่นๆ (optional)
# --------------------------------------------------
# Timezone สำหรับคำนวณวันเมื่อวาน (default: Asia/Bangkok)
TIMEZONE=Asia/Bangkok
